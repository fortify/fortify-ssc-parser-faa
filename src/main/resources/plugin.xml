<?xml version="1.0" encoding="utf-8" ?>
<!-- api-version below is a placeholder: the build replaces it with the version of the
     com.fortify.plugin:plugin-api dependency actually resolved on the compile classpath
     (truncated to major.minor to satisfy the manifest's ApiVersion pattern); see build.gradle. -->
<plugin xmlns="xmlns://www.fortify.com/schema/pluginmanifest-1.1.xsd"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        id="com.fortify.ssc.parser.faa" api-version="0.0">
    <plugin-info>
        <name>Fortify Agentic Analyzer parser plugin</name>
        <version><!--VERSION-->0.0<!--/VERSION--></version>
        <data-version>7</data-version>
        <vendor name="Open Text" url="https://opentext.com"/>
        <description>Parser plugin for Fortify Agentic Analyzer (FAA) SARIF output. Data version 7 corresponds to the SARIF data format produced by FAA 26.4-preview3 and later (per-instance rules, contextRegion snippets, kingdom/SubType property casing, message = one-line summary with description/remediation in the rule's fullDescription/help).</description>
        <resources>
            <localization>
                <language id="default" location="/resources/fortifyaa_en.properties"/>
                <language id="en" location="/resources/fortifyaa_en.properties"/>
            </localization>
            <images>
                <image imageType="icon" location="/images/fortify-aa-icon.png"/>
                <image imageType="logo" location="/images/fortify-aa-logo.png"/>
            </images>
        </resources>
    </plugin-info>
    <issue-parser xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
        <engine-type>FORTIFY_AA</engine-type>
        <!-- supported-engine-versions deliberately omitted (optional per the schema): FAA's
             release labels (e.g. 26.4-preview3) are not expressible in its numeric range
             pattern, and SSC does not act on the value anyway. -->
        <view-template location="/viewtemplate/ViewTemplate.json">
            <description>Fortify Agentic Analyzer vulnerability view template.</description>
        </view-template>
        <parser-type>STATIC</parser-type>
    </issue-parser>
</plugin>
